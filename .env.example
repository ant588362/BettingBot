# The Odds API — https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Whop — https://dev.whop.com
WHOP_API_KEY=your_whop_api_key_here
WHOP_COMPANY_ID=biz_abc123
WHOP_EXPERIENCE_ID=exp_abc123   # optional: scope posts to a specific product
WHOP_FORUM_POST=0               # set to 1 for forum-style posts instead of feed posts

# Shared secret the Whop app sends with every request (set to any random string)
API_SECRET=some_long_random_secret_here
